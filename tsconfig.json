{
  "compilerOptions": {
    "outDir": "./dist",
    "sourceMap": true,
    "module": "nodenext",
    "target": "ESNext",
    "moduleResolution": "nodenext",
    "strict": true,
    "skipLibCheck": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["tests/**/*.ts", "vitest.config.ts"],
  "exclude": ["dist", "node_modules"]
}
